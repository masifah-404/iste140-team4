<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Add an item to your cart.">
    <title>Add to Cart - The Shattered Realms</title>
    <link rel="stylesheet" href="/assets/CSS/style.css">
</head>
<body>
    <nav>
        <div class="nav-container">
            <input type="checkbox" id="menu-toggle" class="menu-toggle">
            <div class="nav-top">
                <div class="nav-header">
                    <div class="logo">
                        <img src="/assets/media/LOGO.jpeg" alt="Campaign Logo">
                    </div>
                </div>
                <div class="logo-center">
                    <img src="/assets/media/NAME.png" alt="The Shattered Realms" class="center-logo">
                </div>
                <label for="menu-toggle" class="hamburger" aria-label="Toggle navigation menu">
                    <span></span><span></span><span></span>
                </label>
            </div>
            <div class="nav-menu-container">
                <ul class="nav-menu">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/character-guide.html" class="nav-link">Character Guide</a></li>
                    <li><a href="/lore-and-world.html" class="nav-link">Lore &amp; World</a></li>
                    <li><a href="/members/add" class="nav-link">Sign Up</a></li>
                    <li><a href="/merch" class="nav-link">Merch Shop</a></li>
                    <li><a href="/cart" class="nav-link active">🛒 Cart</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="page active">
            <div class="container">
                <header>
                    <h1>Add to Cart</h1>
                </header>

                <div class="form-container">
                    <p class="form-intro">
                        Select a product from the shop and choose your quantity.
                    </p>

                    <form action="/cart/add" method="POST" id="cartForm">
                        <div class="form-group">
                            <label for="productId">Choose Product *</label>
                            <select id="productId" name="productId" required aria-required="true">
                                <option value="">Select a product...</option>
                                {{#products}}
                                <option value="{{productId}}">{{productName}} — ${{productPrice}}</option>
                                {{/products}}
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="quantity">Quantity *</label>
                            <input type="number" id="quantity" name="quantity" min="1" value="1"
                                   required aria-required="true">
                        </div>

                        <button type="submit" class="submit-button">Add to Cart</button>
                    </form>

                    <p style="text-align:center; margin-top:1rem;">
                        <a href="/cart" class="internal-link">← View Cart</a> &nbsp;|&nbsp;
                        <a href="/merch" class="internal-link">Browse Shop</a>
                    </p>
                </div>

                <div style="text-align:center; margin-top:2rem;">
                    <a href="/" class="cta-button">← Back to Home</a>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>Dungeons &amp; Dragons is a trademark of Wizards of the Coast LLC.</p>
            <p>&copy; 2025 The Shattered Realms Campaign. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
