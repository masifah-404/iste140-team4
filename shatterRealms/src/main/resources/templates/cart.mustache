<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Your shopping cart for The Shattered Realms merch.">
    <title>Cart - The Shattered Realms</title>
    <link rel="stylesheet" href="/assets/CSS/style.css">
</head>
<body>
    <nav>
        <div class="nav-container">
            <input type="checkbox" id="menu-toggle" class="menu-toggle">
            <div class="nav-top">
                <div class="nav-header">
                    <div class="logo">
                        <img src="/assets/media/LOGO.jpeg" alt="Campaign Logo">
                    </div>
                </div>
                <div class="logo-center">
                    <img src="/assets/media/NAME.png" alt="The Shattered Realms" class="center-logo">
                </div>
                <label for="menu-toggle" class="hamburger" aria-label="Toggle navigation menu">
                    <span></span><span></span><span></span>
                </label>
            </div>
            <div class="nav-menu-container">
                <ul class="nav-menu">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/character-guide.html" class="nav-link">Character Guide</a></li>
                    <li><a href="/lore-and-world.html" class="nav-link">Lore &amp; World</a></li>
                    <li><a href="/members/add" class="nav-link">Sign Up</a></li>
                    <li><a href="/merch" class="nav-link">Merch Shop</a></li>
                    <li><a href="/cart" class="nav-link active">&#x1F6D2; Cart</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="page active">
            <div class="container">
                <section class="page-title">
                    <h1>Your Cart</h1>
                </section>

                <div style="display:flex; justify-content:flex-end; margin-bottom:1.5rem;">
                    <a href="/cart/add" class="cta-button">+ Add Item</a>
                </div>

                <div class="table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Description</th>
                                <th>Unit Price</th>
                                <th>Qty</th>
                                <th>Line Total</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#cartItems}}
                            <tr>
                                <td><strong>{{product.productName}}</strong></td>
                                <td>{{product.productDescription}}</td>
                                <td style="color:var(--accent-gold);">${{product.productPrice}}</td>
                                <td>{{quantity}}</td>
                                <td style="color:var(--accent-gold); font-weight:bold;">${{lineTotal}}</td>
                                <td>
                                    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                                        <!-- UPDATE -->
                                        <a href="/cart/edit/{{productId}}"
                                           style="padding:0.3rem 0.75rem; background:var(--primary-gold); color:var(--primary-dark); border-radius:4px; font-size:0.8rem; font-weight:bold; text-decoration:none;">
                                            Edit
                                        </a>
                                        <!-- DELETE -->
                                        <form action="/cart/delete/{{productId}}" method="POST"
                                              onsubmit="return confirm('Remove this item from your cart?');">
                                            <button type="submit"
                                                    style="padding:0.3rem 0.75rem; background:var(--primary-burgundy); color:white; border:none; border-radius:4px; font-size:0.8rem; font-weight:bold; cursor:pointer;">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/cartItems}}
                            {{^cartItems}}
                            <tr>
                                <td colspan="6" style="text-align:center; color:var(--primary-gold);">
                                    Your cart is empty.
                                    <a href="/merch" class="internal-link">Browse the shop</a>
                                </td>
                            </tr>
                            {{/cartItems}}
                        </tbody>
                    </table>
                </div>

                <div style="text-align:center; margin-top:2rem; display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
                    <a href="/merch" class="cta-button">← Continue Shopping</a>
                    <a href="/" class="cta-button">&#x1F3E0; Back to Home</a>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>Dungeons &amp; Dragons is a trademark of Wizards of the Coast LLC.</p>
            <p>&copy; 2025 The Shattered Realms Campaign. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
