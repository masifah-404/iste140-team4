<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Registered members of The Shattered Realms campaign.">
    <title>Members - The Shattered Realms</title>
    <link rel="stylesheet" href="/assets/CSS/style.css">
</head>
<body>
    <nav>
        <div class="nav-container">
            <input type="checkbox" id="menu-toggle" class="menu-toggle">
            <div class="nav-top">
                <div class="nav-header">
                    <div class="logo">
                        <img src="/assets/media/LOGO.jpeg" alt="Campaign Logo">
                    </div>
                </div>
                <div class="logo-center">
                    <img src="/assets/media/NAME.png" alt="The Shattered Realms" class="center-logo">
                </div>
                <label for="menu-toggle" class="hamburger" aria-label="Toggle navigation menu">
                    <span></span><span></span><span></span>
                </label>
            </div>
            <div class="nav-menu-container">
                <ul class="nav-menu">
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/character-guide.html" class="nav-link">Character Guide</a></li>
                    <li><a href="/lore-and-world.html" class="nav-link">Lore &amp; World</a></li>
                    <li><a href="/members/add" class="nav-link">Sign Up</a></li>
                    <li><a href="/merch" class="nav-link">Merch Shop</a></li>
                    <li><a href="/cart" class="nav-link">Cart</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="page active">
            <div class="container">
                <section class="page-title">
                    <h1>Campaign Members</h1>
                </section>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
                    <p style="margin:0;">All registered adventurers who have joined the Shattered Realms.</p>
                    <a href="/members/add" class="cta-button">+ Register New Member</a>
                </div>

                <div class="table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#members}}
                            <tr>
                                <td>{{memberId}}</td>
                                <td>{{memberName}}</td>
                                <td>{{memberEmail}}</td>
                                <td>
                                    <a href="/members/edit/{{memberId}}"
                                       style="padding:0.3rem 0.75rem; background:var(--primary-gold); color:var(--primary-dark); border-radius:4px; font-size:0.8rem; font-weight:bold; text-decoration:none;">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                            {{/members}}
                            {{^members}}
                            <tr>
                                <td colspan="4" style="text-align:center; color:var(--primary-gold);">
                                    No members registered yet.
                                </td>
                            </tr>
                            {{/members}}
                        </tbody>
                    </table>
                </div>

                <div style="text-align:center; margin-top:2rem;">
                    <a href="/" class="cta-button">&larr; Back to Home</a>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>Dungeons &amp; Dragons is a trademark of Wizards of the Coast LLC.</p>
            <p>&copy; 2025 The Shattered Realms Campaign. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
