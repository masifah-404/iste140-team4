<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Sign up to join The Shattered Realms campaign community.">
    <title>Sign Up - The Shattered Realms</title>
    <link rel="stylesheet" href="/assets/CSS/style.css">
</head>
<body>
<nav>
    <div class="nav-container">
        <input type="checkbox" id="menu-toggle" class="menu-toggle">
        <div class="nav-top">
            <div class="nav-header">
                <div class="logo">
                    <img src="/assets/media/LOGO.jpeg" alt="Campaign Logo">
                </div>
            </div>
            <div class="logo-center">
                <img src="/assets/media/NAME.png" alt="The Shattered Realms" class="center-logo">
            </div>
            <label for="menu-toggle" class="hamburger" aria-label="Toggle navigation menu">
                <span></span><span></span><span></span>
            </label>
        </div>
        <div class="nav-menu-container">
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Home</a></li>
                <li><a href="/character-guide.html" class="nav-link">Character Guide</a></li>
                <li><a href="/lore-and-world.html" class="nav-link">Lore &amp; World</a></li>
                <li><a href="/members/add" class="nav-link active">Sign Up</a></li>
                <li><a href="/merch" class="nav-link">Merch Shop</a></li>
                <li><a href="/cart" class="nav-link">🛒 Cart</a></li>
            </ul>
        </div>
    </div>
</nav>

<main>
    <section class="page active">
        <div class="container">
            <header>
                <h1>Create Your Account</h1>
            </header>

            <div class="form-container">
                <p class="form-intro">
                    Ready to join the Shattered Realms community? Register below to access campaign events,
                    session recaps, and the merch shop.
                </p>

                <form action="/members/add" method="POST" id="signupForm">
                    <div class="form-group">
                        <label for="memberName">Full Name *</label>
                        <input type="text" id="memberName" name="memberName" required aria-required="true"
                               placeholder="Your adventurer name">
                    </div>

                    <div class="form-group">
                        <label for="memberEmail">Email Address *</label>
                        <input type="email" id="memberEmail" name="memberEmail" required aria-required="true"
                               placeholder="you@example.com">
                    </div>

                    <div class="form-group">
                        <label for="memberPassword">Password *</label>
                        <input type="password" id="memberPassword" name="memberPassword" required
                               aria-required="true" minlength="6"
                               placeholder="Minimum 6 characters">
                    </div>

                    <button type="submit" class="submit-button">Create Account</button>
                </form>

                <p style="text-align:center; margin-top:1rem;">
                    Already a member? <a href="/members" class="internal-link">View all members</a>
                </p>
            </div>

            <div style="text-align:center; margin-top:2rem;">
                <a href="/" class="cta-button">← Back to Home</a>
            </div>
        </div>
    </section>
</main>

<footer>
    <div class="container">
        <p>Dungeons &amp; Dragons is a trademark of Wizards of the Coast LLC.</p>
        <p>&copy; 2025 The Shattered Realms Campaign. All rights reserved.</p>
    </div>
</footer>
</body>
</html>
